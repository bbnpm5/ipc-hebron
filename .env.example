# EmailJS Configuration
# Get these values from your EmailJS account at https://www.emailjs.com
# 
# Setup Instructions:
# 1. Sign up at https://www.emailjs.com
# 2. Create an email service (connect your Gmail account: reachipcneria@gmail.com)
# 3. Create email templates with these variables:
#    Prayer Request Template:
#    - {{from_name}}
#    - {{from_email}}
#    - {{phone}}
#    - {{prayer_request}}
#    - {{submitted_at}}
#    Contact Form Template:
#    - {{from_name}}
#    - {{from_email}}
#    - {{phone}}
#    - {{subject}}
#    - {{message}}
#    - {{submitted_at}}
# 4. Copy your Service ID, Template IDs, and Public Key below
# 5. Rename this file to .env and fill in the actual values

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_prayer_request_template_id_here
VITE_EMAILJS_CONTACT_TEMPLATE_ID=your_contact_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here

# YouTube Channel Configuration (uses RSS feed - no API key needed)
# Get your channel ID from YouTube: Channel Settings > Advanced Settings
# Or find it in your channel URL: youtube.com/channel/UCxxxxxxx
VITE_YOUTUBE_CHANNEL_ID=your_channel_id_here
